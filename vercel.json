{
    "version": 2,
    "builds": [
        {
            "src": "*.html",
            "use": "@vercel/static"
        },
        {
            "src": "manifest.json",
            "use": "@vercel/static"
        },
        {
            "src": "favicon.svg",
            "use": "@vercel/static"
        },
        {
            "src": "api/*.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/moderate",
            "dest": "/api/moderate.js"
        },
        {
            "src": "/api/verify-docs",
            "dest": "/api/verify-docs.js"
        },
        {
            "src": "/api/register-equity",
            "dest": "/api/register-equity.js"
        },
        {
            "src": "/api/verify-metrics",
            "dest": "/api/verify-metrics.js"
        },
        {
            "src": "/api/improve-posting(.*)",
            "dest": "/api/improve-posting.js"
        },
        {
            "src": "/api/review-submission(.*)",
            "dest": "/api/review-submission.js"
        },
        {
            "src": "/api/monthly-rewards",
            "dest": "/api/monthly-rewards.js"
        },
        {
            "src": "/api/transfer-equity",
            "dest": "/api/transfer-equity.js"
        },
        {
            "src": "/api/create-room",
            "dest": "/api/create-room.js"
        },
        {
            "src": "/api/valuate-equity",
            "dest": "/api/valuate-equity.js"
        },
        {
            "src": "/api/revaluate-equity",
            "dest": "/api/revaluate-equity.js"
        },
        {
            "src": "/api/resolve-dispute",
            "dest": "/api/resolve-dispute.js"
        },
        {
            "src": "/api/claim-referral-bonus",
            "dest": "/api/claim-referral-bonus.js"
        },
        {
            "src": "/admin.html",
            "dest": "/admin.html"
        },
        {
            "src": "/manifest.json",
            "dest": "/manifest.json"
        },
        {
            "src": "/favicon.svg",
            "dest": "/favicon.svg"
        },
        {
            "src": "/terms",
            "dest": "/terms.html"
        },
        {
            "src": "/privacy",
            "dest": "/privacy.html"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/monthly-rewards",
            "schedule": "0 0 1 * *"
        },
        {
            "path": "/api/revaluate-equity",
            "schedule": "0 0 * * *"
        }
    ]
}
